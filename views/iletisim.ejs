<%- include('partials/header') %>

<section class="page-hero">
    <span class="section-subtitle">İLETİŞİM</span>
    <h1 class="section-title">Bize Ulaşın</h1>
    <p class="section-desc">Sorularınız, önerileriniz veya servis talepleriniz için bizimle iletişime geçebilirsiniz.</p>
</section>

<section class="contact-grid">
    <div class="contact-info-card">
        <h2>İletişim Bilgileri</h2>
        <p>Mağazamızı ziyaret edebilir veya aşağıdaki kanallardan bize ulaşabilirsiniz.</p>

        <div class="info-item">
            <div class="info-icon"><i class="fas fa-location-dot"></i></div>
            <div class="info-details">
                <h4>Adres</h4>
                <p>Örnek Mahallesi, Teknoloji Caddesi No: 42<br>İstanbul, Türkiye</p>
            </div>
        </div>

        <div class="info-item">
            <div class="info-icon"><i class="fas fa-phone"></i></div>
            <div class="info-details">
                <h4>Telefon</h4>
                <p>+90 (555) 123 45 67</p>
            </div>
        </div>

        <div class="info-item">
            <div class="info-icon"><i class="fas fa-envelope"></i></div>
            <div class="info-details">
                <h4>E-posta</h4>
                <p>info@bayim.com</p>
            </div>
        </div>

        <div class="contact-hours">
            <h3><i class="fas fa-clock"></i> Çalışma Saatleri</h3>
            <div class="hours-row"><span>Pazartesi - Cumartesi</span><span>09:00 - 20:00</span></div>
            <div class="hours-row"><span>Pazar</span><span>Kapalı</span></div>
        </div>
    </div>

    <div class="contact-form-card">
        <h2>Mesaj Gönderin</h2>
        <p>Formu doldurun, en kısa sürede size dönüş yapalım.</p>

        <% if (typeof success !== 'undefined' && success) { %>
            <div class="contact-success">
                <i class="fas fa-check-circle"></i> Mesajınız başarıyla gönderildi!
            </div>
        <% } %>

        <% if (typeof error !== 'undefined' && error) { %>
            <div style="background:#fee2e2; color:#b91c1c; padding:15px; border-radius:8px; margin-bottom:20px;">
                <i class="fas fa-exclamation-circle"></i> <%= error %>
            </div>
        <% } %>

        <form action="/iletisim" method="POST">
            <div class="form-row">
                <div class="form-field">
                    <label>Ad Soyad <span>*</span></label>
                    <input type="text" name="name" class="form-input" placeholder="Adınız" required>
                </div>
                <div class="form-field">
                    <label>Telefon</label>
                    <input type="tel" name="phone" class="form-input" placeholder="0(5XX) XXX XX XX" oninput="formatPhone(this)" maxlength="16">
                </div>
            </div>

            <div class="form-field">
                <label>E-posta <span>*</span></label>
                <input type="email" name="email" class="form-input" placeholder="ornek@mail.com" required>
            </div>

            <div class="form-field">
                <label>Konu <span>*</span></label>
                <select name="subject" class="form-input" required>
                    <option value="" disabled selected>Konu seçin</option>
                    <option value="Genel Bilgi">Genel Bilgi</option>
                    <option value="Fiyat Teklifi">Fiyat Teklifi</option>
                    <option value="Teknik Destek">Teknik Destek</option>
                    <option value="Şikayet">Şikayet / Öneri</option>
                    <option value="Diğer">Diğer</option>
                </select>
            </div>

            <div class="form-field">
                <label>Mesajınız <span>*</span></label>
                <textarea name="message" class="form-input" placeholder="Mesajınızı yazın..." required></textarea>
            </div>

            <button type="submit" class="btn-primary form-submit">
                <i class="fas fa-paper-plane"></i> Gönder
            </button>
        </form>
    </div>
</section>

<style>
.faq-block { max-width: 800px; margin: 60px auto 40px auto; padding: 0 5%; }
.faq-block h2 { text-align: center; font-size: 2rem; margin-bottom: 30px; font-family: 'Space Grotesk', sans-serif; }
.faq-item { background: var(--card-bg); border: 1px solid var(--border-color); border-radius: 12px; margin-bottom: 15px; overflow: hidden; }
.faq-question { padding: 20px; font-weight: 600; font-size: 16px; cursor: pointer; display: flex; justify-content: space-between; align-items: center; user-select: none; transition: 0.3s; }
.faq-question:hover { color: var(--primary-accent); background: var(--bg-main); }
.faq-question i { transition: transform 0.3s; }
.faq-item.active .faq-question i { transform: rotate(180deg); color: var(--primary-accent); }
.faq-answer { padding: 0 20px; max-height: 0; overflow: hidden; transition: max-height 0.3s ease-out, padding 0.3s ease; color: var(--text-gray); line-height: 1.6; }
.faq-item.active .faq-answer { padding: 0 20px 20px 20px; max-height: 300px; }
</style>

<section class="faq-block">
    <h2>Sıkça Sorulan Sorular</h2>
    
    <div class="faq-accordion">
        <div class="faq-item">
            <div class="faq-question">Kargo süreci nasıl işliyor? <i class="fas fa-chevron-down"></i></div>
            <div class="faq-answer">16:00'a kadar verilen tüm siparişler aynı gün kargoya teslim edilmektedir. Teslimat süresi bulunduğunuz şehre göre 1-3 iş günü arasında değişmektedir.</div>
        </div>
        
        <div class="faq-item">
            <div class="faq-question">Sıfır cihazlarda garanti süresi nedir? <i class="fas fa-chevron-down"></i></div>
            <div class="faq-answer">Web sitemizden veya mağazamızdan satın aldığınız tüm kapalı kutu sıfır cihazlar, 2 yıl boyunca resmi Türkiye distribütörü (Apple, Samsung Türkiye vb.) garantisi altındadır.</div>
        </div>
        
        <div class="faq-item">
            <div class="faq-question">Teknik servis kayıtlarını nasıl takip edebilirim? <i class="fas fa-chevron-down"></i></div>
            <div class="faq-answer">Cihazınızı servise bıraktığınızda size verilen fiş üzerindeki Takip Numarası ile "Servis" sayfamızdan cihazınızın anlık durumunu adım adım görsel olarak takip edebilirsiniz.</div>
        </div>
        
        <div class="faq-item">
            <div class="faq-question">Ödeme yöntemleriniz nelerdir? Taksit yapıyor musunuz? <i class="fas fa-chevron-down"></i></div>
            <div class="faq-answer">Kredi kartı, Havale/EFT ve mağazada nakit ödeme seçeneklerimiz mevcuttur. Aksesuar ve servis ödemelerinde kredi kartlarına vade farksız taksit imkanımız bulunmaktadır.</div>
        </div>
    </div>
</section>

<script>
// FAQ Accordion logic
document.querySelectorAll('.faq-question').forEach(q => {
    q.addEventListener('click', () => {
        const item = q.parentElement;
        const isActive = item.classList.contains('active');
        
        // Close all others
        document.querySelectorAll('.faq-item').forEach(i => i.classList.remove('active'));
        
        // Toggle current
        if (!isActive) item.classList.add('active');
    });
});

// #10 Phone input mask: 0(5XX) XXX XX XX
function formatPhone(input) {
    let val = input.value.replace(/\D/g, ''); // Only digits
    if(val.length > 11) val = val.slice(0,11);
    let formatted = '';
    if(val.length > 0) formatted = val[0];
    if(val.length > 1) formatted += '(' + val.slice(1,4);
    if(val.length > 4) formatted += ') ' + val.slice(4,7);
    if(val.length > 7) formatted += ' ' + val.slice(7,9);
    if(val.length > 9) formatted += ' ' + val.slice(9,11);
    input.value = formatted;
}
</script>

<%- include('partials/footer') %>
