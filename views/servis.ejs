<%- include('partials/header') %>

<section class="page-hero">
    <span class="section-subtitle">TEKNİK SERVİS</span>
    <h1 class="section-title">Servis Takip & Kayıt</h1>
    <p class="section-desc">Cihazınızın onarım durumunu anlık olarak takip edin veya yeni servis kaydı oluşturun.</p>
</section>

<section class="service-tracking">
    <div class="tracking-wrapper">
        <div style="text-align: center; margin-bottom: 40px;">
            <a href="/servis/kayit" class="btn-primary" style="font-size: 1.1rem; padding: 15px 30px;">
                <i class="fas fa-plus-circle"></i> Yeni Servis Kaydı Oluştur
            </a>
        </div>

        <div class="tracking-box">
            <h3 class="tracking-title">
                <i class="fas fa-search"></i> Servis Sorgula
            </h3>
            <form class="tracking-form">
                <input type="text" class="tracking-input" placeholder="Servis Takip No (Örn: #1024)">
                <button type="submit" class="btn-primary">Sorgula</button>
            </form>
        </div>

        <div class="orders-section">
            <h3 class="orders-title">Son Teknik İşlemler</h3>
            <div class="orders-list">
                <% orders.forEach(order => { 
                    let step = 1;
                    if(order.status === 'Onarımda') step = 2;
                    if(order.status === 'Hazır') step = 3;
                %>
                    <div class="order-row" style="display:block; padding:25px;">
                        <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:30px; flex-wrap:wrap; gap:15px;">
                            <div>
                                <span class="order-id" style="font-size:13px; font-weight:700; color:var(--text-gray); display:block; margin-bottom:5px;">#<%= order.id %></span>
                                <h4 class="order-device" style="font-size:18px; margin:0 0 5px 0; color:var(--text-main);"><%= order.device_model %></h4>
                                <p class="order-customer" style="font-size:14px; color:var(--text-gray); margin:0;"><i class="far fa-user"></i> <%= order.customer_name %></p>
                            </div>
                            <div class="order-status">
                                <span class="status-badge <%= order.status === 'Hazır' ? 'done' : order.status === 'Onarımda' ? 'repairing' : 'pending' %>" style="display:inline-block;">
                                    <% if(step === 1) { %><i class="fas fa-clock"></i><% } %>
                                    <% if(step === 2) { %><i class="fas fa-wrench"></i><% } %>
                                    <% if(step === 3) { %><i class="fas fa-check-circle"></i><% } %>
                                    <%= order.status %>
                                </span>
                            </div>
                        </div>

                        <!-- TIMELINE UI -->
                        <div class="timeline" style="display:flex; justify-content:space-between; position:relative; padding-top:10px; max-width:80%; margin:0 auto;">
                            <!-- Line Background -->
                            <div style="position:absolute; top:22px; left:10%; right:10%; height:4px; background:#f1f5f9; z-index:1; border-radius:4px;"></div>
                            
                            <!-- Line Progress -->
                            <div style="position:absolute; top:22px; left:10%; height:4px; background:<%= step >= 3 ? '#16a34a' : 'var(--primary-accent)' %>; z-index:1; width:<%= step === 1 ? '0%' : (step === 2 ? '40%' : '80%') %>; transition:1s ease; border-radius:4px;"></div>
                            
                            <!-- Steps -->
                            <div style="position:relative; z-index:2; text-align:center; flex:1;">
                                <div style="width:28px; height:28px; border-radius:50%; background:<%= step >= 1 ? 'var(--primary-accent)' : '#f1f5f9' %>; color:<%= step >= 1 ? 'white' : '#cbd5e1' %>; margin:0 auto 12px auto; display:flex; align-items:center; justify-content:center; font-size:12px; box-shadow:<%= step >= 1 ? '0 0 0 4px rgba(14,165,233,0.1)' : 'none' %>; transition:0.3s;"><i class="fas fa-check"></i></div>
                                <span style="font-size:13px; font-weight:600; color:<%= step >= 1 ? 'var(--text-main)' : 'var(--text-gray)' %>;">Teslim Alındı</span>
                            </div>
                            
                            <div style="position:relative; z-index:2; text-align:center; flex:1;">
                                <div style="width:28px; height:28px; border-radius:50%; background:<%= step >= 2 ? 'var(--primary-accent)' : '#f1f5f9' %>; color:<%= step >= 2 ? 'white' : '#cbd5e1' %>; margin:0 auto 12px auto; display:flex; align-items:center; justify-content:center; font-size:12px; box-shadow:<%= step >= 2 ? '0 0 0 4px rgba(14,165,233,0.1)' : 'none' %>; transition:0.3s;"><% if(step >= 2) { %><i class="fas fa-check"></i><% } else { %><i class="fas fa-circle" style="font-size:6px;"></i><% } %></div>
                                <span style="font-size:13px; font-weight:600; color:<%= step >= 2 ? 'var(--text-main)' : 'var(--text-gray)' %>;">Onarımda</span>
                            </div>
                            
                            <div style="position:relative; z-index:2; text-align:center; flex:1;">
                                <div style="width:28px; height:28px; border-radius:50%; background:<%= step >= 3 ? '#16a34a' : '#f1f5f9' %>; color:<%= step >= 3 ? 'white' : '#cbd5e1' %>; margin:0 auto 12px auto; display:flex; align-items:center; justify-content:center; font-size:12px; box-shadow:<%= step >= 3 ? '0 0 0 4px rgba(22,163,74,0.1)' : 'none' %>; transition:0.3s;"><% if(step >= 3) { %><i class="fas fa-check"></i><% } else { %><i class="fas fa-circle" style="font-size:6px;"></i><% } %></div>
                                <span style="font-size:13px; font-weight:600; color:<%= step >= 3 ? 'var(--text-main)' : 'var(--text-gray)' %>;">Hazır</span>
                            </div>
                        </div>
                    </div>
                <% }) %>
            </div>
        </div>
    </div>
</section>

<%- include('partials/footer') %>
