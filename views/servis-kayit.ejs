<%- include('partials/header') %>

<section class="page-hero">
    <span class="section-subtitle">TEKNİK SERVİS</span>
    <h1 class="section-title">Servis Kaydı Oluştur</h1>
    <p class="section-desc">Cihazınız için onarım talebi oluşturun, size en kısa sürede dönüş yapalım.</p>
</section>

<section class="register-section">
    <div class="register-wrapper">

        <% if (typeof success !== 'undefined' && success) { %>
            <div class="success-box">
                <i class="fas fa-check-circle"></i>
                <h3>Servis Kaydınız Alındı</h3>
                <p>En kısa sürede sizinle iletişime geçeceğiz. Takip numaranız e-posta ile gönderilecektir.</p>
            </div>
        <% } %>

        <% if (typeof error !== 'undefined' && error) { %>
            <div style="background:#fee2e2; color:#b91c1c; padding:15px; border-radius:8px; margin-bottom:20px;">
                <i class="fas fa-exclamation-circle"></i> <%= error %>
            </div>
        <% } %>

        <div class="register-card">
            <h2>Cihaz & İletişim Bilgileri</h2>
            <p class="form-subtitle">Aşağıdaki formu doldurarak servis kaydı oluşturabilirsiniz.</p>

            <form action="/servis/kayit" method="POST">
                <div class="form-row">
                    <div class="form-field">
                        <label>Ad Soyad <span>*</span></label>
                        <input type="text" name="customer_name" class="form-input" placeholder="Adınızı girin" required>
                    </div>
                    <div class="form-field">
                        <label>Telefon <span>*</span></label>
                        <input type="tel" name="phone" class="form-input" placeholder="05xxxxxxxxx" pattern="[0-9]{10,11}" title="Lütfen 10 veya 11 haneli telefon numaranızı girin" required>
                    </div>
                </div>

                <div class="form-field">
                    <label>E-posta</label>
                    <input type="email" name="email" class="form-input" placeholder="ornek@mail.com">
                </div>

                <div class="form-row">
                    <div class="form-field">
                        <label>Cihaz Markası <span>*</span></label>
                        <select name="brand" class="form-input" required>
                            <option value="" disabled selected>Marka seçin</option>
                            <option value="Apple">Apple</option>
                            <option value="Samsung">Samsung</option>
                            <option value="Xiaomi">Xiaomi</option>
                            <option value="Huawei">Huawei</option>
                            <option value="Diger">Diğer</option>
                        </select>
                    </div>
                    <div class="form-field">
                        <label>Cihaz Modeli <span>*</span></label>
                        <input type="text" name="device_model" class="form-input" placeholder="Örn: iPhone 14 Pro" required>
                    </div>
                </div>

                <div class="form-field">
                    <label>Arıza Türü <span>*</span></label>
                    <select name="issue_type" class="form-input" required>
                        <option value="" disabled selected>Arıza türünü seçin</option>
                        <option value="Ekran Değişimi">Ekran Değişimi</option>
                        <option value="Batarya Değişimi">Batarya Değişimi</option>
                        <option value="Şarj Soketi">Şarj Soketi Onarımı</option>
                        <option value="Kamera Onarımı">Kamera Onarımı</option>
                        <option value="Yazılım Sorunu">Yazılım Sorunu</option>
                        <option value="Su/Sıvı Teması">Su / Sıvı Teması</option>
                        <option value="Diğer">Diğer</option>
                    </select>
                </div>

                <div class="form-field">
                    <label>Arıza Açıklaması</label>
                    <textarea name="description" class="form-input" placeholder="Cihazınızda yaşadığınız sorunu kısaca açıklayın..."></textarea>
                </div>

                <button type="submit" class="btn-primary form-submit">
                    <i class="fas fa-paper-plane"></i> Kaydı Gönder
                </button>
            </form>

            <p class="form-note">
                <i class="fas fa-lock"></i> Bilgileriniz gizli tutulur ve yalnızca servis sürecinde kullanılır.
            </p>
        </div>
    </div>
</section>

<%- include('partials/footer') %>
