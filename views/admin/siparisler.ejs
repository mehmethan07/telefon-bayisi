<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Siparişler & Ayırtmalar | <%= firma_adi %> Yönetim</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Space+Grotesk:wght@700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
    <link rel="stylesheet" href="/css/admin.css">
</head>
<body>
    <div class="admin-layout">
        <%- include('partials/sidebar', { activePage: 'siparisler' }) %>

        <div class="admin-main">
            <%- include('partials/topbar', { pageTitle: 'Sipariş / Ayırtmalar', pageIcon: 'fas fa-store', badgeCount: reservations.length }) %>

            <% if (reservations.length === 0) { %>
                <div class="empty-state">
                    <i class="fas fa-box-open"></i>
                    <h3>Henüz ayırtılmış ürün yok</h3>
                    <p>Müşteriler mağazadan teslim al seçeneğini kullandığında talepler burada görünür.</p>
                </div>
            <% } else { %>
                <div class="res-list">
                    <% reservations.slice().reverse().forEach(res => { %>
                        <div class="res-card">
                            <div class="res-info">
                                <h3 style="margin-bottom:10px;"><i class="fas fa-shopping-bag"></i> Sipariş #<%= String(res.id).slice(-6) %> - <%= res.items.length %> Ürün</h3>
                                <p><strong>Müşteri:</strong> <%= res.customer_name %> | <strong>Tel:</strong> <%= res.phone %></p>

                                <!-- Detayları Gör Butonu -->
                                <button class="btn" style="background:#e0f2fe; color:#0284c7; border:1px solid #bae6fd; font-weight:600; font-size:13px; padding:6px 12px; border-radius:6px; margin: 10px 0;" data-items="<%= encodeURIComponent(JSON.stringify(res.items)) %>" data-price="<%= res.total_price %>" onclick="openOrderModal(this)">
                                    <i class="fas fa-list-ul"></i> Sipariş İçeriğini Gör
                                </button>

                                <div class="res-meta" style="margin-top:10px;">
                                    <span><i class="far fa-clock"></i> <%= res.date %></span>
                                    <span><i class="fas fa-money-bill"></i> Toplam: <%= res.total_price %> TL (<%= res.payment_method %>)</span>
                                </div>
                            </div>
                            
                            <div class="res-actions" style="margin-top:0; min-width: 150px; display:flex; flex-direction:column; justify-content:center; align-items:flex-end;">
                                <form action="/admin/siparisler/<%= res.id %>/durum" method="POST">
                                    <select name="status" onchange="this.form.submit()" style="padding:10px; border-radius:8px; font-weight:600; cursor:pointer; font-size:14px; background: <%= res.status === 'Beklemede' ? '#fffbeb' : (res.status === 'Onaylandı' ? '#f0fdf4' : '#fef2f2') %>; color: <%= res.status === 'Beklemede' ? '#d97706' : (res.status === 'Onaylandı' ? '#16a34a' : '#dc2626') %>; border: 1px solid <%= res.status === 'Beklemede' ? '#fde68a' : (res.status === 'Onaylandı' ? '#bbf7d0' : '#fecaca') %>;">
                                        <option value="Beklemede" <%= res.status === 'Beklemede' ? 'selected' : '' %>>Beklemede</option>
                                        <option value="Onaylandı" <%= res.status === 'Onaylandı' ? 'selected' : '' %>>Onaylandı</option>
                                        <option value="İptal Edildi" <%= res.status === 'İptal Edildi' ? 'selected' : '' %>>İptal Edildi</option>
                                    </select>
                                </form>
                            </div>
                        </div>
                    <% }) %>
                </div>
            <% } %>

            <!-- Sipariş Detay Modalı -->
            <div id="orderModal" class="modal">
                <div class="modal-content" style="max-width:500px;">
                    <div class="modal-header">
                        <h2><i class="fas fa-box-open" style="color:var(--primary); margin-right:8px;"></i> Sipariş Detayı</h2>
                        <button class="close-btn" onclick="document.getElementById('orderModal').style.display = 'none';">&times;</button>
                    </div>
                    <div id="orderItemsContainer" style="margin-top:20px;">
                        <!-- Dynamic list generated by JS -->
                    </div>
                    <div style="margin-top:20px; padding-top:15px; border-top:2px dashed #e2e8f0; display:flex; justify-content:space-between; align-items:center;">
                        <span style="font-size:16px; font-weight:600; color:var(--text-gray);">Toplam Tutar:</span>
                        <span id="orderTotalPrice" style="font-size:20px; font-weight:700; color:var(--primary);"></span>
                    </div>
                </div>
            </div>
            
            <script>
                function openOrderModal(btn) {
                    const itemsJsonString = decodeURIComponent(btn.getAttribute('data-items'));
                    const totalPrice = btn.getAttribute('data-price');
                    const items = JSON.parse(itemsJsonString);
                    const container = document.getElementById('orderItemsContainer');
                    let html = '';
                    
                    items.forEach(s => {
                        html += `
                        <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:12px; padding:12px; background:#f8fafc; border:1px solid #e2e8f0; border-radius:8px;">
                            <div style="display:flex; align-items:center; gap:12px;">
                                <div style="background:var(--primary); color:white; width:30px; height:30px; border-radius:50%; display:flex; justify-content:center; align-items:center; font-weight:700; font-size:14px;">${s.miktar}x</div>
                                <div>
                                    <h4 style="margin:0; font-size:15px; color:var(--text-main);">${s.item.name}</h4>
                                    <p style="margin:2px 0 0 0; font-size:12px; color:var(--text-gray);">${s.item.brand || s.item.category}</p>
                                </div>
                            </div>
                            <span style="font-weight:600; color:var(--text-main); font-size:15px;">${s.item.price} TL</span>
                        </div>
                        `;
                    });

                    container.innerHTML = html;
                    document.getElementById('orderTotalPrice').textContent = totalPrice + ' TL';
                    document.getElementById('orderModal').style.display = 'flex';
                }

                window.onclick = function(event) {
                    if (event.target.classList.contains('modal')) event.target.style.display = 'none';
                }
            </script>
        </div>
    </div>
</body>
</html>
