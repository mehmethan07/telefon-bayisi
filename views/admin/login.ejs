<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Yönetim Paneli | <%= firma_adi %></title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Space+Grotesk:wght@700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
    <link rel="stylesheet" href="/css/admin.css">
</head>
<body class="login-page">
    <div class="login-box">
        <div class="login-logo">
            <i class="fas fa-mobile-screen-button"></i>
        </div>
        <div class="brand">BAYİM<span>.</span></div>
        <p class="subtitle">Yönetim Paneline Hoşgeldiniz</p>

        <form action="/admin/login" method="POST">
            <div class="form-group">
                <label>E-posta</label>
                <div class="input-group">
                    <i class="fas fa-envelope"></i>
                    <input type="email" name="email" placeholder="E-posta adresiniz" required>
                </div>
            </div>

            <div class="form-group">
                <label>Şifre</label>
                <div class="input-group">
                    <i class="fas fa-lock"></i>
                    <input type="password" name="password" placeholder="Şifreniz" required>
                </div>
            </div>

            <button type="submit" class="btn-login">
                <i class="fas fa-sign-in-alt"></i> Giriş Yap
            </button>
        </form>

        <div class="footer-links">
            <a href="/"><i class="fas fa-arrow-left"></i> Mağazaya Dön</a>
        </div>
    </div>
</body>
</html>