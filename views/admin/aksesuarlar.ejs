<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Aksesuar Yönetimi | <%= firma_adi %> Yönetim</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Space+Grotesk:wght@700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
    <link rel="stylesheet" href="/css/admin.css">
</head>
<body>
    <div class="admin-layout">
        <%- include('partials/sidebar', { activePage: 'aksesuarlar' }) %>

        <div class="admin-main">
            <%- include('partials/topbar', { pageTitle: 'Aksesuar Yönetimi', pageIcon: 'fas fa-headphones', badgeCount: aksesuarlar.length }) %>

            <% if (typeof success !== 'undefined' && success) { %>
                <div class="toast toast-success"><i class="fas fa-check-circle"></i> <%= success %></div>
            <% } %>

            <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:20px; flex-wrap:wrap; gap:10px;">
                <div style="display:flex; gap:10px;">
                    <button class="btn btn-add" onclick="openModal('addModal')" style="margin:0;"><i class="fas fa-plus"></i> Yeni Aksesuar Ekle</button>
                    <button class="btn" style="background:var(--card-bg); color:var(--text-main); border:1px solid var(--border-color); font-weight:600; cursor:pointer; padding:10px 16px; border-radius:8px;" onclick="exportToCSV()"><i class="fas fa-download"></i> CSV İndir</button>
                </div>
                <div class="admin-search" style="margin:0;">
                    <input type="text" id="tableSearch" placeholder="Tabloda ara..." oninput="filterTable(this.value)">
                </div>
            </div>

            <% if (aksesuarlar.length === 0) { %>
                <div class="empty-state">
                    <i class="fas fa-headphones"></i>
                    <h3>Henüz aksesuar eklenmemiş</h3>
                    <p>İlk aksesuarınızı eklemek için yukarıdaki butonu kullanın.</p>
                </div>
            <% } else { %>
            <table id="aksesuarDataTable">
                <thead>
                    <tr>
                        <th style="width:40px;"><input type="checkbox" id="selectAll" onclick="toggleAllCheckboxes(this)"></th>
                        <th>ID</th>
                        <th>İkon</th>
                        <th>Aksesuar Adı</th>
                        <th>Kategori</th>
                        <th>Fiyat</th>
                        <th>İşlemler</th>
                    </tr>
                </thead>
                <tbody id="aksTable">
                    <% aksesuarlar.map((a,idx) => { %>
                        <tr>
                            <td><input type="checkbox" class="rowCheckbox" value="<%= a.id %>"></td>
                            <td><%= a.id %></td>
                            <td><i class="<%= a.icon %>" style="font-size:22px; color:var(--primary);"></i></td>
                            <td style="font-weight:600;"><%= a.name %></td>
                            <td><%= a.category %></td>
                            <td><%= a.price %> TL</td>
                            <td>
                                <button class="btn btn-edit" onclick="openEditModal('<%= a.id %>', '<%= a.name %>', '<%= a.category %>', '<%= a.price %>', '<%= a.icon %>')"><i class="fas fa-edit"></i></button>
                                <form action="/admin/aksesuarlar/<%= a.id %>/sil" method="POST" style="display:inline;" onsubmit="return confirm('Bu aksesuarı silmek istediğinize emin misiniz?');">
                                    <button class="btn btn-delete"><i class="fas fa-trash"></i></button>
                                </form>
                            </td>
                        </tr>
                    <% }) %>
                </tbody>
            </table>
            <% } %>

            <!-- Ekleme Modalı -->
            <div id="addModal" class="modal">
                <div class="modal-content">
                    <div class="modal-header">
                        <h2><i class="fas fa-plus-circle" style="color:var(--primary); margin-right:8px;"></i> Yeni Aksesuar Ekle</h2>
                        <button class="close-btn" onclick="closeModal('addModal')">&times;</button>
                    </div>
                    <form action="/admin/aksesuarlar/ekle" method="POST">
                        <div class="form-group">
                            <label>Aksesuar Adı</label>
                            <input type="text" name="name" placeholder="Örn: iPhone 15 Pro Kılıf" required>
                        </div>
                        <div class="form-group">
                            <label>Kategori <span style="font-size:12px; color:var(--text-gray);">(Seç veya Yaz)</span></label>
                            <input list="catDict" name="category" placeholder="Kategori Seç / Yaz" autocomplete="off" required>
                            <datalist id="catDict">
                                <% uniqueCategories.forEach(c => { %>
                                    <option value="<%= c.name %>">
                                <% }) %>
                            </datalist>
                        </div>
                        <div class="form-group">
                            <label>Fiyat (TL)</label>
                            <input type="number" name="price" step="0.01" min="0" placeholder="Örn: 500" required>
                        </div>
                        <div class="form-group">
                            <label>FontAwesome İkonu (örn: fas fa-plug)</label>
                            <input type="text" name="icon" value="fas fa-plug">
                        </div>
                        <button type="submit" class="btn btn-add" style="width:100%; justify-content:center; padding:12px;">Kaydet</button>
                    </form>
                </div>
            </div>

            <!-- Düzenleme Modalı -->
            <div id="editModal" class="modal">
                <div class="modal-content">
                    <div class="modal-header">
                        <h2><i class="fas fa-edit" style="color:#f59e0b; margin-right:8px;"></i> Aksesuar Düzenle</h2>
                        <button class="close-btn" onclick="closeModal('editModal')">&times;</button>
                    </div>
                    <form id="editForm" method="POST">
                        <div class="form-group">
                            <label>Aksesuar Adı</label>
                            <input type="text" name="name" id="edit_name" required>
                        </div>
                        <div class="form-group">
                            <label>Kategori <span style="font-size:12px; color:var(--text-gray);">(Seç veya Yaz)</span></label>
                            <input list="catDict" name="category" id="edit_category" autocomplete="off" required>
                        </div>
                        <div class="form-group">
                            <label>Fiyat</label>
                            <input type="text" name="price" id="edit_price" required>
                        </div>
                        <div class="form-group">
                            <label>FontAwesome İkonu</label>
                            <input type="text" name="icon" id="edit_icon">
                        </div>
                        <button type="submit" class="btn btn-edit" style="width:100%; justify-content:center; padding:12px;">Güncelle</button>
                    </form>
                </div>
            </div>
        </div>
    </div>

    <script>
        function openModal(id) { document.getElementById(id).style.display = 'flex'; }
        function closeModal(id) { document.getElementById(id).style.display = 'none'; }

        function openEditModal(id, name, cat, price, icon) {
            document.getElementById('editForm').action = '/admin/aksesuarlar/' + id + '/duzenle';
            document.getElementById('edit_name').value = name;
            document.getElementById('edit_category').value = cat;
            document.getElementById('edit_price').value = price;
            document.getElementById('edit_icon').value = icon;
            openModal('editModal');
        }

        function filterTable(query) {
            const rows = document.querySelectorAll('#aksTable tr');
            const q = query.toLowerCase();
            rows.forEach(row => { row.style.display = row.textContent.toLowerCase().includes(q) ? '' : 'none'; });
        }

        // CSV Export Data
        function exportToCSV() {
            const table = document.getElementById('aksesuarDataTable');
            let csv = [];
            const rows = table.querySelectorAll('tr');
            
            for (let i = 0; i < rows.length; i++) {
                let row = [], cols = rows[i].querySelectorAll('td, th');
                for (let j = 1; j < cols.length - 1; j++) {
                    let text = cols[j].innerText.replace(/(\r\n|\n|\r)/gm, '').trim();
                    row.push('"' + text + '"');
                }
                if(row.length > 0) csv.push(row.join(','));
            }

            const csvFile = new Blob(["\uFEFF"+csv.join('\n')], {type: "text/csv;charset=utf-8;"});
            const downloadLink = document.createElement("a");
            downloadLink.download = "aksesuarlar_raporu.csv";
            downloadLink.href = window.URL.createObjectURL(csvFile);
            downloadLink.style.display = "none";
            document.body.appendChild(downloadLink);
            downloadLink.click();
            document.body.removeChild(downloadLink);
        }

        // Toplu Seçim (Bulk Select)
        function toggleAllCheckboxes(source) {
            const checkboxes = document.querySelectorAll('.rowCheckbox');
            checkboxes.forEach(cb => { cb.checked = source.checked; });
        }

        window.onclick = function(event) { if (event.target.classList.contains('modal')) event.target.style.display = 'none'; }
    </script>
</body>
</html>
